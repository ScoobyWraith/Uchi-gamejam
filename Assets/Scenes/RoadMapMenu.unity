    - target: {fileID: 7327899364035152533, guid: 16f2c22d83449ff4e8099a0d792a62a8, type: 3}
      propertyPath: m_Text
      value: "\u041D\u043E, \u043A\u0430\u043A \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E,
        \u0447\u0435\u043C \u0431\u043E\u043B\u044C\u0448\u0435 - \u0442\u0435\u043C
        \u0432\u0435\u0441\u0435\u043B\u0435\u0435!\n\n\u0422\u0435\u043F\u0435\u0440\u044C
        \u043D\u0443\u0436\u043D\u043E \u043F\u0435\u0440\u0435\u043F\u043B\u044B\u0442\u044C
        \u043D\u0430 \u0432\u0442\u043E\u0440\u043E\u0439 \u043E\u0441\u0442\u0440\u043E\u0432
        \u0447\u0435\u0440\u0435\u0437 \u043C\u043E\u0440\u0435, \u0432 \u044D\u0442\u043E\u043C
        \u043D\u0430\u043C \u043F\u043E\u043C\u043E\u0436\u0435\u0442 \u043D\u043E\u0432\u044B\u0439
        \u0432\u0435\u0440\u043D\u044B\u0439 \u0434\u0440\u0443\u0433!\n\n\u041F\u043E\u0435\u0445\u0430\u043B\u0438!"
