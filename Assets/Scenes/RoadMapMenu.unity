    - target: {fileID: 7327899364035152533, guid: 16f2c22d83449ff4e8099a0d792a62a8, type: 3}
      propertyPath: m_Text
      value: "\u0412\u0435\u043B\u0438\u043A\u043E\u043B\u0435\u043F\u043D\u043E!
        \u041C\u044B \u0434\u043E\u0431\u0440\u0430\u043B\u0438\u0441\u044C \u0434\u043E
        \u0434\u0430\u043B\u044C\u043D\u0435\u0433\u043E \u043E\u0441\u0442\u0440\u043E\u0432\u0430!
        \u0413\u0434\u0435-\u0442\u043E \u0437\u0434\u0435\u0441\u044C \u043C\u043E\u0439
        \u0434\u0440\u0443\u0433 \u043A\u0430\u043F\u0438\u0442\u0430\u043D...\n\n\u041D\u0430\u043C
        \u043F\u043E\u043D\u0430\u0434\u043E\u0431\u0438\u0442\u0441\u044F \u0435\u0449\u0451
        \u043E\u0434\u0438\u043D \u0433\u0435\u0440\u043E\u0439, \u043A\u0442\u043E
        \u0441\u043C\u043E\u0436\u0435\u0442 \u043D\u0430\u0439\u0442\u0438 \u0435\u0433\u043E
        \u0437\u0434\u0435\u0441\u044C \u0438 \u043E\u0442\u0434\u0430\u0442\u044C
        \u043A\u0430\u0440\u0442\u0443 \u0441\u043E\u043A\u0440\u043E\u0432\u0438\u0449!"
      objectReference: {fileID: 0}
