        \u043F\u043E\u0434 \u043C\u043E\u0440\u0435\u043C, \u0447\u0435\u0440\u0435\u0437
        \u043F\u043E\u0434\u0437\u0435\u043C\u0435\u043B\u044C\u0435!\n\n"
