  m_Script: {fileID: 11500000, guid: 3e2de279c74cd53489ca27cbb17ae004, type: 3}
  m_Name: Whale
  m_EditorClassIdentifier: 
  folder: Origami_whale
  items:
  - fileName: origami_whale_01
    text: "\u0412\u043E\u0437\u044C\u043C\u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0439
      \u043B\u0438\u0441\u0442 \u0431\u0443\u043C\u0430\u0433\u0438 \u0438 \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0438
      \u0435\u0433\u043E \u0440\u043E\u043C\u0431\u043E\u043C \u0432\u0432\u0435\u0440\u0445.
      \u0421\u043B\u043E\u0436\u0438 \u043F\u043E \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u0438
      \u043F\u043E \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u0438, \u0437\u0430\u0442\u0435\u043C
      \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0438 \u043E\u0431\u0440\u0430\u0442\u043D\u043E."
  - fileName: origami_whale_02
    text: "\u0422\u0435\u043F\u0435\u0440\u044C \u0441\u043B\u043E\u0436\u0438 \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
      \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u044C, \u0437\u0430\u0442\u0435\u043C
      \u0441\u043D\u043E\u0432\u0430 \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0438
      \u043E\u0431\u0440\u0430\u0442\u043D\u043E."
  - fileName: origami_whale_03
    text: "\u0421\u043E\u0433\u043D\u0438 \u043D\u0438\u0436\u043D\u0438\u0439 \u043B\u0435\u0432\u044B\u0439
      \u0438 \u043D\u0438\u0436\u043D\u0438\u0439 \u043F\u0440\u0430\u0432\u044B\u0439
      \u043A\u0440\u0430\u044F \u043A \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439
      \u043B\u0438\u043D\u0438\u0438."
  - fileName: origami_whale_04
    text: "\u0421\u043E\u0433\u043D\u0438 \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u043B\u0435\u0432\u044B\u0439 \u0438 \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u043F\u0440\u0430\u0432\u044B\u0439 \u043A\u0440\u0430\u044F \u043A \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439
      \u043B\u0438\u043D\u0438\u0438."
  - fileName: origami_whale_05
    text: "\u0421\u0432\u0435\u0440\u043D\u0438 \u043F\u043E \u0438\u043C\u0435\u044E\u0449\u0438\u043C\u0441\u044F
      \u0441\u043A\u043B\u0430\u0434\u043A\u0430\u043C, \u0447\u0442\u043E\u0431\u044B
      \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430\u0441\u044C \u043E\u0441\u043D\u043E\u0432\u0430
      \u0442\u0435\u043B\u0430 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0433\u043E."
  - fileName: origami_whale_06
    text: "\u0417\u0430\u0442\u0435\u043C \u043E\u0442\u043E\u0433\u043D\u0438 \u043A\u043E\u043D\u0447\u0438\u043A
      \u0442\u0430\u043A, \u0447\u0442\u043E\u0431\u044B \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u0443\u0433\u043E\u043B \u043D\u0430\u0445\u043E\u0434\u0438\u043B\u0441\u044F
      \u043D\u0430 \u0442\u043E\u043C \u0436\u0435 \u0443\u0440\u043E\u0432\u043D\u0435,
      \u0447\u0442\u043E \u0438 \u043E\u0431\u0432\u0435\u0434\u0435\u043D\u043D\u0430\u044F
      \u0442\u043E\u0447\u043A\u0430. \u0417\u0430\u0442\u0435\u043C \u043F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0438
      \u043C\u043E\u0434\u0435\u043B\u044C."
  - fileName: origami_whale_07
    text: "\u0421\u043B\u0435\u0433\u043A\u0430 \u0437\u0430\u0433\u043D\u0438 \u043B\u0435\u0432\u044B\u0439
      \u0438 \u043F\u0440\u0430\u0432\u044B\u0439 \u0443\u0433\u043B\u044B \u0432\u043D\u0443\u0442\u0440\u044C.
      \u041E\u043D\u0438 \u0434\u043E\u043B\u0436\u043D\u044B \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u0442\u044C
      \u0441 \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
      \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u044C\u044E."
  - fileName: origami_whale_08
    text: "\u0421\u043B\u043E\u0436\u0438 \u043C\u043E\u0434\u0435\u043B\u044C \u043F\u043E\u043F\u043E\u043B\u0430\u043C
      \u0441\u043F\u0440\u0430\u0432\u0430 \u043D\u0430\u043B\u0435\u0432\u043E.
      \u0417\u0430\u0442\u0435\u043C \u043F\u043E\u0432\u0435\u0440\u043D\u0438\u0442\u0435
      \u043D\u0430 90 \u0433\u0440\u0430\u0434\u0443\u0441\u043E\u0432 \u043F\u0440\u043E\u0442\u0438\u0432
      \u0447\u0430\u0441\u043E\u0432\u043E\u0439 \u0441\u0442\u0440\u0435\u043B\u043A\u0438."
  - fileName: origami_whale_09
    text: "\u041E\u0442\u043E\u0433\u043D\u0438 \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u043A\u043B\u0430\u043F\u0430\u043D \u0432\u043D\u0438\u0437, \u0447\u0442\u043E\u0431\u044B
      \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0441\u044F \u043F\u043B\u0430\u0432\u043D\u0438\u043A.
      \u0417\u0430\u0442\u0435\u043C \u043F\u043E\u0432\u0442\u043E\u0440\u0438 \u0442\u0430\u043A\u0436\u0435
      \u0441 \u0434\u0440\u0443\u0433\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B."
  - fileName: origami_whale_10
    text: "\u0421\u043B\u043E\u0436\u0438 \u0433\u043E\u0440\u043A\u043E\u0439, \u0447\u0442\u043E\u0431\u044B
      \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0441\u044F \u0445\u0432\u043E\u0441\u0442."
  - fileName: origami_whale_11
    text: "\u041A\u0430\u043A\u043E\u0435 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435
      \u0443 \u0442\u0435\u0431\u044F \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u043E\u0441\u044C?"
