  m_Script: {fileID: 11500000, guid: 3e2de279c74cd53489ca27cbb17ae004, type: 3}
  m_Name: Frog
  m_EditorClassIdentifier: 
  folder: Origami_frog
  items:
  - fileName: origami_frog_01
    text: "\u0412\u043E\u0437\u044C\u043C\u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0439
      \u043B\u0438\u0441\u0442 \u0431\u0443\u043C\u0430\u0433\u0438. \u0421\u043B\u043E\u0436\u0438
      \u0435\u0433\u043E \u043F\u043E\u043F\u043E\u043B\u0430\u043C \u043F\u043E
      \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u0438, \u0437\u0430\u0442\u0435\u043C
      \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0438.."
  - fileName: origami_frog_02
    text: "\u0421\u043B\u043E\u0436\u0438 \u0431\u0443\u043C\u0430\u0433\u0443 \u043F\u043E\u043F\u043E\u043B\u0430\u043C
      \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u043E, \u0441\u043B\u0435\u0432\u0430
      \u043D\u0430\u043F\u0440\u0430\u0432\u043E."
  - fileName: origami_frog_03
    text: "\u0421\u043D\u043E\u0432\u0430 \u0441\u043B\u043E\u0436\u0438 \u0431\u0443\u043C\u0430\u0433\u0443
      \u043F\u043E\u043F\u043E\u043B\u0430\u043C \u043F\u043E \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u0438,
      \u0437\u0430\u0442\u0435\u043C \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0438.\n\u0421\u043E\u0432\u0435\u0442
      \u043F\u043E \u0441\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u043D\u0438\u044E:
      \u041F\u0435\u0440\u0435\u0434 \u0441\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u043D\u0438\u0435\u043C
      \u043F\u043E\u043B\u043E\u0436\u0438 \u043F\u0430\u043B\u044C\u0446\u044B \u043D\u0430
      \u043F\u0440\u0430\u0432\u0443\u044E \u0441\u0442\u043E\u0440\u043E\u043D\u0443,
      \u0447\u0442\u043E\u0431\u044B \u0441\u043A\u0440\u0435\u043F\u0438\u0442\u044C
      \u0432\u0441\u0435 \u0441\u043B\u043E\u0438, \u0447\u0442\u043E\u0431\u044B
      \u043E\u043D\u0438 \u043D\u0435 \u0441\u043C\u0435\u0449\u0430\u043B\u0438\u0441\u044C."
  - fileName: origami_frog_04
    text: "\u041F\u043E\u0434\u043E\u0433\u043D\u0438 \u043F\u0440\u0430\u0432\u044B\u0439
      \u043D\u0438\u0436\u043D\u0438\u0439 \u043A\u0440\u0430\u0439 \u043A \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
      \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u043B\u0438\u043D\u0438\u0438.
      \u0425\u043E\u0440\u043E\u0448\u043E \u0441\u043B\u043E\u0436\u0438, \u0437\u0430\u0442\u0435\u043C
      \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0438 \u043E\u0431\u0440\u0430\u0442\u043D\u043E."
  - fileName: origami_frog_05
    text: "\u041F\u043E\u0434\u043E\u0433\u043D\u0438 \u043D\u0438\u0436\u043D\u0438\u0439
      \u043B\u0435\u0432\u044B\u0439 \u043A\u0440\u0430\u0439 \u043A \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
      \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u043B\u0438\u043D\u0438\u0438.
      \u0425\u043E\u0440\u043E\u0448\u043E \u0441\u043B\u043E\u0436\u0438, \u0437\u0430\u0442\u0435\u043C
      \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0438 \u043E\u0431\u0440\u0430\u0442\u043D\u043E."
  - fileName: origami_frog_06
    text: "\u041F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0438 \u0431\u0443\u043C\u0430\u0433\u0443."
  - fileName: origami_frog_07
    text: "\u041F\u043E\u0434\u043E\u0433\u043D\u0438 \u043D\u0438\u0436\u043D\u0438\u0439
      \u043A\u0440\u0430\u0439 \u043A \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
      \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u043B\u0438\u043D\u0438\u0438.
      \u0425\u043E\u0440\u043E\u0448\u043E \u0441\u043B\u043E\u0436\u0438, \u0437\u0430\u0442\u0435\u043C
      \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0438\u0442\u0435."
  - fileName: origami_frog_08
    text: "\u041F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0438 \u043C\u043E\u0434\u0435\u043B\u044C\u043A\u0443."
  - fileName: origami_frog_09
    text: "\u0417\u0430\u0433\u043D\u0438 \u043D\u0438\u0436\u043D\u044E\u044E \u043B\u0435\u0432\u0443\u044E
      \u0438 \u043F\u0440\u0430\u0432\u0443\u044E \u0441\u0442\u043E\u0440\u043E\u043D\u044B
      \u0432\u043D\u0443\u0442\u0440\u044C, \u043E\u0434\u043D\u043E\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
      \u0437\u0430\u0433\u0438\u0431\u0430\u044F \u043D\u0438\u0436\u043D\u0438\u0439
      \u043A\u0440\u0430\u0439 \u0432\u0432\u0435\u0440\u0445 \u0442\u0430\u043A,
      \u0447\u0442\u043E\u0431\u044B \u043E\u043D \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u043B
      \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
      \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u043B\u0438\u043D\u0438\u0438."
  - fileName: origami_frog_10
    text: "\u0417\u0430\u0433\u043D\u0438 \u0432\u0435\u0440\u0445\u043D\u0438\u0435
      \u0441\u0442\u0432\u043E\u0440\u043A\u0438 \u0432\u043D\u0438\u0437. \u0422\u043E\u0447\u043D\u044B\u0445
      \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440\u043E\u0432 \u0437\u0434\u0435\u0441\u044C
      \u043D\u0435\u0442. \u042D\u0442\u043E \u0431\u0443\u0434\u0443\u0442 \u043F\u0435\u0440\u0435\u0434\u043D\u0438\u0435
      \u043B\u0430\u043F\u043A\u0438, \u043F\u043E\u044D\u0442\u043E\u043C\u0443
      \u043F\u043E\u0441\u0442\u0430\u0440\u0430\u0439\u0441\u044F \u0441\u0434\u0435\u043B\u0430\u0442\u044C
      \u0438\u0445 \u0441\u0438\u043C\u043C\u0435\u0442\u0440\u0438\u0447\u043D\u044B\u043C\u0438."
  - fileName: origami_frog_11
    text: "\u041F\u043E\u0432\u0435\u0440\u043D\u0438\u0442\u0435 \u043C\u043E\u0434\u0435\u043B\u044C\u043A\u0443
      \u043D\u0430 180 \u0433\u0440\u0430\u0434\u0443\u0441\u043E\u0432."
  - fileName: origami_frog_12
    text: "\u0417\u0430\u0433\u043D\u0438 \u043D\u0438\u0436\u043D\u0438\u0439 \u043A\u0440\u0430\u0439
      \u0432\u0432\u0435\u0440\u0445 \u0434\u043E \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u0439
      \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
      \u043B\u0438\u043D\u0438\u0438."
  - fileName: origami_frog_13
    text: "\u041F\u043E\u0434\u043E\u0433\u043D\u0438 \u043B\u0435\u0432\u044B\u0439
      \u0438 \u043F\u0440\u0430\u0432\u044B\u0439 \u043A\u0440\u0430\u044F \u043A
      \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439 \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439
      \u043B\u0438\u043D\u0438\u0438.\n\u0421\u043E\u0432\u0435\u0442 \u043F\u043E
      \u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u043D\u0438\u044E: \u041F\u0435\u0440\u0435\u0434
      \u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u043D\u0438\u0435\u043C \u043F\u0440\u0438\u043F\u043E\u0434\u043D\u0438\u043C\u0438
      \u043F\u0435\u0440\u0435\u0434\u043D\u0438\u0435 \u043E\u0442\u043A\u0438\u0434\u043D\u044B\u0435
      \u0441\u0442\u0432\u043E\u0440\u043A\u0438, \u0447\u0442\u043E\u0431\u044B
      \u043E\u043D\u0438 \u043D\u0435 \u043C\u0435\u0448\u0430\u043B\u0438."
  - fileName: origami_frog_14
    text: "\u0417\u0430\u0433\u043D\u0438 \u043D\u0438\u0436\u043D\u0438\u0439 \u043A\u0440\u0430\u0439
      \u0442\u0430\u043A, \u0447\u0442\u043E\u0431\u044B \u043E\u043D \u0441\u043E\u0432\u043F\u0430\u0434\u0430\u043B
      \u0441 \u043C\u0435\u0441\u0442\u043E\u043C \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F
      \u043F\u0435\u0440\u0435\u0434\u043D\u0438\u0445 \u043D\u043E\u0436\u0435\u043A."
  - fileName: origami_frog_15
    text: "\u0417\u0430\u0433\u043D\u0438 \u043B\u0435\u0432\u044B\u0439 \u0438 \u043F\u0440\u0430\u0432\u044B\u0439
      \u043A\u0440\u0430\u044F \u0432\u0435\u0440\u0445\u043D\u0435\u0433\u043E \u043A\u043B\u0430\u043F\u0430\u043D\u0430
      \u0432\u043D\u0438\u0437 \u043A \u043D\u0438\u0436\u043D\u0435\u043C\u0443
      \u043A\u0440\u0430\u044E, \u0437\u0430\u0442\u0435\u043C \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0438
      \u0438\u0445 \u043E\u0431\u0440\u0430\u0442\u043D\u043E."
  - fileName: origami_frog_16
    text: "\u041E\u0442\u043A\u0438\u043D\u044C \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u043A\u043B\u0430\u043F\u0430\u043D, \u043A\u0430\u043A \u043F\u043E\u043A\u0430\u0437\u0430\u043D\u043E
      \u043D\u0430 \u0448\u0430\u0433\u0435 14."
  - fileName: origami_frog_17
    text: "\u041F\u043E\u0434\u043D\u0438\u043C\u0438 \u043D\u0438\u0436\u043D\u0438\u0435
      \u0441\u0442\u0432\u043E\u0440\u043A\u0438 \u0438 \u043F\u0440\u0438\u043F\u043E\u0434\u043D\u0438\u043C\u0438\u0442\u0435
      \u043D\u0438\u0436\u043D\u0438\u0439 \u043A\u0440\u0430\u0439 \u0434\u043E
      \u0442\u043E\u0447\u043A\u0438 \u0441\u043E\u0435\u0434\u0438\u043D\u0435\u043D\u0438\u044F
      \u043F\u0435\u0440\u0435\u0434\u043D\u0438\u0445 \u043D\u043E\u0436\u0435\u043A.
      \u041D\u0438\u0436\u043D\u0438\u0435 \u0441\u0442\u0432\u043E\u0440\u043A\u0438
      \u0431\u0443\u0434\u0443\u0442 \u0432\u044B\u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F
      \u043D\u0430\u0440\u0443\u0436\u0443 \u0441 \u043A\u0430\u0436\u0434\u043E\u0439
      \u0441\u0442\u043E\u0440\u043E\u043D\u044B."
  - fileName: origami_frog_18
    text: "\u0421\u043B\u043E\u0436\u0438 \u043B\u0435\u0432\u044B\u0439 \u0438 \u043F\u0440\u0430\u0432\u044B\u0439
      \u043A\u043B\u0430\u043F\u0430\u043D\u044B \u0432\u043D\u0438\u0437 \u043F\u043E
      \u0438\u043C\u0435\u044E\u0449\u0438\u043C\u0441\u044F \u0441\u043A\u043B\u0430\u0434\u043A\u0430\u043C."
  - fileName: origami_frog_19
    text: "\u041F\u043E\u0434\u043E\u0433\u043D\u0438 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0435
      \u043A\u0440\u0430\u044F \u043D\u0438\u0436\u043D\u0438\u0445 \u043B\u043E\u0441\u043A\u0443\u0442\u043E\u0432
      \u043A \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0438\u043C \u043B\u0438\u043D\u0438\u044F\u043C
      \u0441\u0433\u0438\u0431\u0430, \u0447\u0442\u043E\u0431\u044B \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u0437\u0430\u0434\u043D\u0438\u0435 \u043B\u0430\u043F\u043A\u0438."
  - fileName: origami_frog_20
    text: "\u0421\u043B\u043E\u0436\u0438 \u043D\u0438\u0436\u043D\u044E\u044E \u0447\u0430\u0441\u0442\u044C
      \u0432\u0432\u0435\u0440\u0445 \u043F\u043E \u043B\u0438\u043D\u0438\u0438,
      \u0433\u0434\u0435 \u0441\u0445\u043E\u0434\u044F\u0442\u0441\u044F \u043F\u0435\u0440\u0435\u0434\u043D\u0438\u0435
      \u0438 \u0437\u0430\u0434\u043D\u0438\u0435 \u043D\u043E\u0436\u043A\u0438."
  - fileName: origami_frog_21
    text: "\u0421\u043B\u043E\u0436\u0438 \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u043A\u043B\u0430\u043F\u0430\u043D \u043F\u043E\u043F\u043E\u043B\u0430\u043C
      \u0441\u0432\u0435\u0440\u0445\u0443 \u0432\u043D\u0438\u0437. \u0425\u043E\u0440\u043E\u0448\u043E
      \u0440\u0430\u0441\u043F\u0440\u0430\u0432\u044C."
  - fileName: origami_frog_22
    text: "\u041F\u0435\u0440\u0435\u0432\u0435\u0440\u043D\u0438 \u043C\u043E\u0434\u0435\u043B\u044C\u043A\u0443
      \u0438 \u0430\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u043E \u0432\u044B\u0442\u044F\u043D\u0438\u0442\u0435
      \u0437\u0430\u0434\u043D\u0438\u0435 \u043D\u043E\u0436\u043A\u0438."
  - fileName: origami_frog_23
    text: "\u041A\u0430\u043A\u043E\u0435 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435
      \u0443 \u0442\u0435\u0431\u044F \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u043E\u0441\u044C?"
