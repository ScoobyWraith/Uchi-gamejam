  m_Script: {fileID: 11500000, guid: 3e2de279c74cd53489ca27cbb17ae004, type: 3}
  m_Name: Eagle
  m_EditorClassIdentifier: 
  folder: Origami_eagle
  items:
  - fileName: origami_eagle_01
    text: "\u0412\u043E\u0437\u044C\u043C\u0438 \u043A\u0432\u0430\u0434\u0440\u0430\u0442\u043D\u044B\u0439
      \u043B\u0438\u0441\u0442 \u0431\u0443\u043C\u0430\u0433\u0438 \u0438 \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0438
      \u0435\u0433\u043E \u0440\u043E\u043C\u0431\u043E\u043C \u0432\u0432\u0435\u0440\u0445.
      \u0421\u043B\u043E\u0436\u0438\u0442\u0435 \u0438 \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0438\u0442\u0435
      \u043B\u0438\u0441\u0442 \u043F\u043E \u0432\u0435\u0440\u0442\u0438\u043A\u0430\u043B\u044C\u043D\u043E\u0439
      \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u0438."
  - fileName: origami_eagle_02
    text: "\u0421\u043B\u043E\u0436\u0438 \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u0443\u044E
      \u043B\u0438\u043D\u0438\u044E \u043F\u043E \u0434\u0438\u0430\u0433\u043E\u043D\u0430\u043B\u0438
      \u0441\u043D\u0438\u0437\u0443 \u0432\u0432\u0435\u0440\u0445."
  - fileName: origami_eagle_03
    text: "\u041E\u043F\u0443\u0441\u0442\u0438 \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u0443\u0433\u043E\u043B \u0432\u0435\u0440\u0445\u043D\u0435\u0433\u043E \u0441\u043B\u043E\u044F
      \u0442\u0430\u043A, \u0447\u0442\u043E\u0431\u044B \u043E\u043D \u0441\u043E\u043F\u0440\u0438\u043A\u0430\u0441\u0430\u043B\u0441\u044F
      \u0441 \u043D\u0438\u0436\u043D\u0438\u043C \u043A\u0440\u0430\u0435\u043C.
      \u0421\u043B\u0435\u0433\u043A\u0430 \u0437\u0430\u0449\u0438\u043F\u043D\u0438
      \u0446\u0435\u043D\u0442\u0440, \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430\u0441\u044C
      \u0442\u043E\u0447\u043A\u0430 \u043E\u0442\u0441\u0447\u0435\u0442\u0430."
  - fileName: origami_eagle_04
    text: "\u0417\u0430\u0433\u043D\u0438 \u0442\u043E\u0442 \u0436\u0435 \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u0443\u0433\u043E\u043B\u043E\u043A \u0442\u0430\u043A, \u0447\u0442\u043E\u0431\u044B
      \u043E\u043D \u0441\u043E\u043E\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u043E\u0432\u0430\u043B
      \u0442\u043E\u043B\u044C\u043A\u043E \u0447\u0442\u043E \u0441\u0434\u0435\u043B\u0430\u043D\u043D\u043E\u043C\u0443
      \u0437\u0430\u0449\u0438\u043F\u044B\u0432\u0430\u043D\u0438\u044E. \u0417\u0430\u0442\u0435\u043C
      \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0438.."
  - fileName: origami_eagle_05
    text: "\u0417\u0430\u0433\u043D\u0438 \u043D\u0438\u0436\u043D\u0438\u0439 \u043A\u0440\u0430\u0439
      \u0434\u043E \u0441\u0433\u0438\u0431\u0430, \u0441\u0434\u0435\u043B\u0430\u043D\u043D\u043E\u0433\u043E
      \u043D\u0430 \u043F\u0440\u0435\u0434\u0443\u0449\u0435\u043C \u0448\u0430\u0433\u0435."
  - fileName: origami_eagle_06
    text: "C\u043D\u043E\u0432\u0430 \u0437\u0430\u0433\u043D\u0438 \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u0443\u0433\u043E\u043B\u043E\u043A \u0432\u043D\u0438\u0437 \u043F\u043E
      \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u044E\u0449\u0435\u0439 \u0441\u043A\u043B\u0430\u0434\u043A\u0435
      (\u0442\u043E\u043B\u044C\u043A\u043E \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u0441\u043B\u043E\u0439)."
  - fileName: origami_eagle_07
    text: "\u0417\u0430\u0433\u043D\u0438 \u043F\u0440\u0430\u0432\u044B\u0439 \u043D\u0438\u0436\u043D\u0438\u0439
      \u0443\u0433\u043E\u043B \u0442\u0430\u043A, \u0447\u0442\u043E\u0431\u044B
      \u043E\u043D \u0441\u043E\u0432\u043F\u0430\u043B \u0441 \u0432\u0435\u0440\u0445\u043D\u0438\u043C
      \u0443\u0433\u043B\u043E\u043C. \u0412\u044B\u0440\u043E\u0432\u043D\u044F\u0439
      \u043D\u0438\u0436\u043D\u0438\u0439 \u043A\u0440\u0430\u0439 \u043F\u043E
      \u0446\u0435\u043D\u0442\u0440\u0430\u043B\u044C\u043D\u043E\u0439 \u043B\u0438\u043D\u0438\u0438."
  - fileName: origami_eagle_08
    text: "\u041E\u0442\u043E\u0433\u043D\u0438 \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u043A\u043B\u0430\u043F\u0430\u043D \u0432\u043D\u0438\u0437 \u043F\u043E
      \u043B\u0438\u043D\u0438\u0438, \u0433\u0434\u0435 \u0441\u0445\u043E\u0434\u044F\u0442\u0441\u044F
      \u0431\u0435\u043B\u0430\u044F \u0438 \u0446\u0432\u0435\u0442\u043D\u0430\u044F
      \u0441\u0442\u043E\u0440\u043E\u043D\u044B."
  - fileName: origami_eagle_09
    text: "\u041F\u043E\u0432\u0442\u043E\u0440\u0438 \u0448\u0430\u0433\u0438 7
      \u0438 8, \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0435\u043F\u0435\u0440\u044C
      \u0441 \u043B\u0435\u0432\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B."
  - fileName: origami_eagle_10
    text: "\u041E\u0442\u043A\u0438\u043D\u044C \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u043A\u043B\u0430\u043F\u0430\u043D."
  - fileName: origami_eagle_11
    text: "\u0421\u0432\u0435\u0434\u0438 \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u0443\u0433\u043E\u043B \u0432\u0435\u0440\u0445\u043D\u0435\u0433\u043E \u0441\u043B\u043E\u044F
      \u043A \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u0439 \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
      \u043B\u0438\u043D\u0438\u0438. \u0417\u0430\u0436\u043C\u0438 \u0446\u0435\u043D\u0442\u0440,
      \u0447\u0442\u043E\u0431\u044B \u043E\u0442\u043C\u0435\u0442\u0438\u0442\u044C
      \u0442\u043E\u0447\u043A\u0443 \u043E\u0442\u0441\u0447\u0435\u0442\u0430."
  - fileName: origami_eagle_12
    text: "\u0421\u043B\u043E\u0436\u0438 \u0449\u0435\u043F\u043E\u0442\u043A\u0443
      \u043E\u0442 \u0448\u0430\u0433\u0430 11 \u0432\u043D\u0438\u0437 \u0434\u043E
      \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u0439 \u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442\u0430\u043B\u044C\u043D\u043E\u0439
      \u043B\u0438\u043D\u0438\u0438 (\u0442\u043E\u043B\u044C\u043A\u043E \u0432
      \u043E\u0434\u0438\u043D \u0441\u043B\u043E\u0439)."
  - fileName: origami_eagle_13
    text: "\u0421\u043B\u043E\u0436\u0438 \u043F\u0440\u0430\u0432\u043E\u0435 \u043A\u0440\u044B\u043B\u044B\u0448\u043A\u043E
      \u0432\u0434\u043E\u043B\u044C \u043F\u0443\u043D\u043A\u0442\u0438\u0440\u043D\u043E\u0439
      \u043B\u0438\u043D\u0438\u0438. \u0421\u043A\u043B\u0430\u0434\u043A\u0430
      \u0434\u043E\u043B\u0436\u043D\u0430 \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u0442\u044C
      \u043E\u0442 \u0432\u0435\u0440\u0445\u043D\u0435\u0433\u043E \u0438 \u043D\u0438\u0436\u043D\u0435\u0433\u043E
      \u0443\u0433\u043B\u043E\u0432 \u043A\u0440\u044B\u043B\u044B\u0448\u043A\u0430.\n\u0421\u043E\u0432\u0435\u0442
      \u043F\u043E \u0441\u0433\u0438\u0431\u0430\u043D\u0438\u044E: \u041D\u0430\u0447\u0438\u043D\u0430\u044F
      \u0441 \u0448\u0430\u0433\u043E\u0432 13-15, \u0430\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u043E
      \u0441\u043B\u043E\u0436\u0438, \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0438\u0441\u044C
      \u043E\u0441\u0442\u0440\u044B\u0435, \u0430\u043A\u043A\u0443\u0440\u0430\u0442\u043D\u044B\u0435
      \u043A\u0440\u044B\u043B\u044B\u0448\u043A\u0438."
  - fileName: origami_eagle_14
    text: "\u0417\u0430\u0433\u043D\u0438 \u0432\u0435\u0440\u0445\u043D\u044E\u044E
      \u0441\u0442\u0432\u043E\u0440\u043A\u0443 \u043A\u0440\u044B\u043B\u0430 \u0432\u043F\u0440\u0430\u0432\u043E.
      \u0421\u0434\u0435\u043B\u0430\u0439 \u0441\u043A\u043B\u0430\u0434\u043A\u0443
      \u0442\u0430\u043A, \u0447\u0442\u043E\u0431\u044B \u043E\u043D\u0430 \u043E\u0431\u0440\u0430\u0437\u043E\u0432\u044B\u0432\u0430\u043B\u0430
      \u0443\u0433\u043E\u043B 90\xB0 \u043F\u043E \u043D\u0438\u0436\u043D\u0435\u043C\u0443
      \u043A\u0440\u0430\u044E, \u0438\u0434\u044F \u043E\u0442 \u0432\u0435\u0440\u0445\u043D\u0435\u0433\u043E
      \u0443\u0433\u043B\u0430 \u0432\u043D\u0438\u0437."
  - fileName: origami_eagle_15
    text: "\u0421\u043B\u043E\u0436\u0438 \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u043B\u0435\u0432\u044B\u0439 \u043A\u0440\u0430\u0439 \u043A\u0440\u044B\u043B\u044B\u0448\u043A\u0430
      \u0442\u0430\u043A, \u0447\u0442\u043E\u0431\u044B \u043E\u043D \u0441\u043E\u043F\u0440\u0438\u043A\u0430\u0441\u0430\u043B\u0441\u044F
      \u0441 \u043F\u0440\u0430\u0432\u044B\u043C \u043A\u0440\u0430\u0435\u043C.
      \u041D\u0443\u0436\u043D\u043E \u0441\u043A\u043B\u0430\u0434\u044B\u0432\u0430\u0442\u044C
      \u0432 \u0431\u0443\u0434\u0435\u0442 \u0434\u0432\u0430 \u0441\u043B\u043E\u044F."
  - fileName: origami_eagle_16
    text: "\u0420\u0430\u0437\u0432\u0435\u0440\u043D\u0438 \u043A\u0440\u044B\u043B\u043E,
      \u043D\u0435 \u0440\u0430\u0441\u043F\u0440\u0430\u0432\u043B\u044F\u044F \u0435\u0433\u043E
      \u043F\u043E\u043B\u043D\u043E\u0441\u0442\u044C\u044E."
  - fileName: origami_eagle_17
    text: "\u041F\u043E\u0432\u0442\u043E\u0440\u0438 \u0448\u0430\u0433\u0438 \u0441
      13 \u043F\u043E 16, \u0442\u043E\u043B\u044C\u043A\u043E \u0442\u0435\u043F\u0435\u0440\u044C
      \u0434\u043B\u044F \u043B\u0435\u0432\u043E\u0433\u043E \u043A\u0440\u044B\u043B\u0430."
  - fileName: origami_eagle_18
    text: "\u0417\u0430\u0433\u043D\u0438 \u0432\u0435\u0440\u0445\u043D\u0438\u0439
      \u0443\u0433\u043E\u043B \u0432\u043D\u0438\u0437 \u0432\u0434\u043E\u043B\u044C
      \u043F\u0443\u043D\u043A\u0442\u0438\u0440\u043D\u043E\u0439 \u043B\u0438\u043D\u0438\u0438.
      \u0422\u043E\u0447\u043D\u043E\u0439 \u0442\u043E\u0447\u043A\u0438 \u043E\u0442\u0441\u0447\u0435\u0442\u0430
      \u043D\u0435\u0442."
  - fileName: origami_eagle_19
    text: "\u0417\u0430\u0433\u043D\u0438 \u043F\u0440\u0430\u0432\u0443\u044E \u043F\u043E\u043B\u043E\u0432\u0438\u043D\u0443
      \u043C\u043E\u0434\u0435\u043B\u0438 \u0437\u0430 \u043D\u0435\u0435."
  - fileName: origami_eagle_20
    text: "\u041F\u043E\u0432\u0435\u0440\u043D\u0438 \u043C\u043E\u0434\u0435\u043B\u044C
      \u043D\u0430 90\xB0 \u043F\u043E \u0447\u0430\u0441\u043E\u0432\u043E\u0439
      \u0441\u0442\u0440\u0435\u043B\u043A\u0435."
  - fileName: origami_eagle_21
    text: "\u0421\u043B\u043E\u0436\u0438 \u0438 \u0440\u0430\u0437\u0432\u0435\u0440\u043D\u0438
      \u043A\u0440\u044B\u043B\u044B\u0448\u043A\u0438 \u0432\u0434\u043E\u043B\u044C
      \u043F\u0443\u043D\u043A\u0442\u0438\u0440\u043D\u044B\u0445 \u043B\u0438\u043D\u0438\u0439,
      \u0447\u0442\u043E\u0431\u044B \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C
      \u0440\u0430\u0441\u0441\u0442\u043E\u044F\u043D\u0438\u0435 \u043C\u0435\u0436\u0434\u0443
      \u043A\u0440\u044B\u043B\u044B\u0448\u043A\u0430\u043C\u0438 \u0438 \u0442\u0443\u043B\u043E\u0432\u0438\u0449\u0435\u043C.
      \u041F\u043E\u0432\u0442\u043E\u0440\u0438 \u0441 \u0434\u0440\u0443\u0433\u043E\u0439
      \u0441\u0442\u043E\u0440\u043E\u043D\u044B."
  - fileName: origami_eagle_22
    text: "\u041F\u043E\u0442\u044F\u043D\u0438 \u0432\u043D\u0438\u0437 \u043A\u043B\u0430\u043F\u0430\u043D,
      \u043D\u0430\u0447\u0438\u043D\u0430\u044F \u0441 \u0448\u0430\u0433\u0430
      18, \u0447\u0442\u043E\u0431\u044B \u0441\u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u0442\u044C
      \u043A\u043B\u044E\u0432."
  - fileName: origami_eagle_23
    text: "\u041A\u0430\u043A\u043E\u0435 \u0436\u0438\u0432\u043E\u0442\u043D\u043E\u0435
      \u0443 \u0442\u0435\u0431\u044F \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u043E\u0441\u044C?"
