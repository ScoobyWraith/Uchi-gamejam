  m_text: "\u041F\u0440\u0438\u0432\u0435\u0442, \u043E\u0442\u0432\u0430\u0436\u043D\u044B\u0439
    \u0438\u0441\u043A\u0430\u0442\u0435\u043B\u044C \u043F\u0440\u0438\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0439!\n\u0413\u043E\u0442\u043E\u0432
    \u043B\u0438 \u0442\u044B \u0441\u043E\u0431\u0440\u0430\u0442\u044C \u0432\u0435\u0440\u043D\u0443\u044E
    \u043A\u043E\u043C\u0430\u043D\u0434\u0443, \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u044C
    \u0422\u0430\u0438\u043D\u0441\u0442\u0432\u0435\u043D\u043D\u044B\u0435 \u043E\u0441\u0442\u0440\u043E\u0432\u0430,
    \u0440\u0435\u0448\u0438\u0442\u044C \u043C\u043E\u0440\u0441\u043A\u0438\u0435
    \u0437\u0430\u0433\u0430\u0434\u043A\u0438 \u0438 \u043D\u0430\u0439\u0442\u0438
    \u043A\u043B\u0430\u0434?"
